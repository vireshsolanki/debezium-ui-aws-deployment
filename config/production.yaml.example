# ── AWS ───────────────────────────────────────────────────────────────────────
account:     "123456789012"
region:      "ap-south-1"
environment: "production"

# ── Networking ────────────────────────────────────────────────────────────────
vpc_id: "vpc-XXXXXXXXXXXXXXXXX"
private_subnet_ids:
  - "subnet-AAAAAAAA"    # AZ-a
  - "subnet-BBBBBBBB"    # AZ-b
  - "subnet-CCCCCCCC"    # AZ-c

# ── MSK (IAM auth, port 9098) ─────────────────────────────────────────────────
msk_cluster_arn: "arn:aws:kafka:ap-south-1:123456789012:cluster/your-cluster/xxxx-1"
msk_bootstrap_servers: >-
  b-1.your-msk.xxxx.c1.kafka.ap-south-1.amazonaws.com:9098,
  b-2.your-msk.xxxx.c1.kafka.ap-south-1.amazonaws.com:9098

# ── RDS MySQL credentials ─────────────────────────────────────────────────────
# CDK creates the Secrets Manager secret shell with placeholder values.
# After deploy, fill real values in AWS Console → Secrets Manager.
# Secret name: debezium-cdc/mysql-credentials

# ── Naming convention — all AWS resources follow: {naming_prefix}-{component} ─
naming_prefix: "debezium-cdc"

# ── CDC source database + tables ──────────────────────────────────────────────
# Debezium topic naming: {cdc_topic_prefix}{cdc_topic_delimiter}{database}{delimiter}{table}
cdc_database:         "your_database"
cdc_topic_prefix:     "dz"
cdc_topic_delimiter:  "-"
cdc_tables:
  - "table_one"
#  - "table_two"   # uncomment to add more tables
# Output topics (read-only reference — generated by Debezium from the above)
cdc_output_topics:
  - "dz-your_database-table_one"
#  - "dz-your_database-table_two"   # uncomment when adding table_two

# ── Kafka Connect state topics (already created — do NOT rename) ──────────────
kafka_topics:
  config:         "debezium-configs"
  offsets:        "debezium-offsets"
  status:         "debezium-status"
  schema_history: "debezium-schema-history"

# ── Debezium Connect workers ──────────────────────────────────────────────────
connect_group_id:       "debezium-cdc-connect"
debezium_image_tag:     "2.7"
debezium_worker_count:  3       # initial desired count
debezium_worker_min:    2       # auto-scale floor  — never 0, binlog window is 72h
debezium_worker_max:    10      # auto-scale ceiling
debezium_cpu:           1024    # 1 vCPU  (Fargate units)
debezium_memory_mib:    2048    # 2 GB RAM

# ── Debezium UI ───────────────────────────────────────────────────────────────
deploy_ui:      true
ui_image_tag:   "latest"

# ── ALB / TLS ─────────────────────────────────────────────────────────────────
# ACM certificate must already be issued and validated for domain_name
acm_certificate_arn: "arn:aws:acm:ap-south-1:123456789012:certificate/YOUR_CERT_ID"
domain_name:         "debezium.yourdomain.com"

# ── Tags — applied to every AWS resource in the stack ────────────────────────
tags:
  Product:     "YourProduct"
  ManagedBy:   "CDK"
